{
  "expo": {
    "name": "Rondo",
    "slug": "rondo",
    "version": "1.0.0",
    "scheme": "rondo",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0A0A",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rondo.app"
    },
    "android": {
      "package": "com.rondo.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/icon.png"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      ["expo-splash-screen", {
        "backgroundColor": "#0A0A0A",
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain"
      }]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
