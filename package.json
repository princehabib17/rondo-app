{
  "name": "rondo-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "web:dev": "node ./node_modules/next/dist/bin/next dev --webpack -p 3000",
    "web:dev:turbo": "node ./node_modules/next/dist/bin/next dev -p 3000",
    "web:build": "node ./node_modules/next/dist/bin/next build",
    "web:start": "node ./node_modules/next/dist/bin/next start",
    "web:lint": "eslint",
    "web:test": "vitest run",
    "dev": "node ./node_modules/next/dist/bin/next dev --webpack -p 3000",
    "dev:turbo": "node ./node_modules/next/dist/bin/next dev -p 3000",
