    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "react-leaflet": "^5.0.0",
    "shadcn": "^4.7.0",
