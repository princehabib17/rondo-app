    "start": "node ./node_modules/next/dist/bin/next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "mobile:install": "npm --prefix mobile install --legacy-peer-deps",
    "mobile:start": "npm --prefix mobile start",
    "mobile:android": "npm --prefix mobile run android",
    "mobile:ios": "npm --prefix mobile run ios",
    "mobile:web": "npm --prefix mobile run web",
    "mobile:typecheck": "npm --prefix mobile run typecheck",
    "mobile:doctor": "npm --prefix mobile run doctor",
    "db:types": "supabase gen types typescript --local > lib/supabase/database.types.ts"
  },
