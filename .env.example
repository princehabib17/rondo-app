# Supabase (required — app will not authenticate without these)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# App URL (required for PayMongo redirects and webhooks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Passkeys (Supabase Auth beta): enable in Dashboard → Authentication → Passkeys
# Relying Party ID = bare domain (e.g. localhost or rondo-app.vercel.app)
# Origins = http://localhost:3000 and your production URL

# PayMongo (required for wallet top-up and payment webhooks)
PAYMONGO_SECRET_KEY=sk_test_...
PAYMONGO_WEBHOOK_SECRET_KEY=whsk_...
